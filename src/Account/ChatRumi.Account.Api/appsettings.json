{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "ChatRumi",
    "Audience": "ChatRumi",
    "SigningKey": "local_dev_jwt_signing_key_at_least_32_chars",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 14
  },
  "ConnectionStrings": {
    "accountDatabase": "Host=postgres;Port=5432;Database=accountdb;Username=postgres;Password=postgres",
    "MassTransit": "amqp://RABBITMQ_USER:RABBITMQ_PASSWORD@rabbitmq:5672/"
  },
  "OtpOptions": {
    "Expiration": 300,
    "Originator": "CHATRUM"
  },
  "SmsOfficeOptions": {
    "ApiKey": "e26114283af846029074d0bc192972f0",
    "BaseUrl": "https://smsoffice.ge"
  },
  "RedisOptions": {
    "Host": "redis",
    "Port": 6379,
    "User": "default",
    "Password": "",
    "Expiration": 2
  },
  "KafkaOptions": {
    "ConnectionString": "kafka:29092"
  },
  "ConsulOptions": {
    "ServiceName": "accountservice",
    "ServiceAddress": "http://account-service:5049",
    "Host": "consul",
    "Scheme": "http",
    "Port": 8500,
    "Enabled": true
  },
  "OpenTelemetry": {
    "ServiceName": "account-service",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://jaeger:4317",
    "Enabled": true
  }
}
