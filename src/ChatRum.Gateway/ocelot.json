      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "UseWebSockets": true,
      "DownstreamHttpVersion": "1.1",
      "LoadBalancerOptions": {
        "Type": "LeastConnection"
      }
    },
    {
      "DownstreamPathTemplate": "/hub/notifications/{everything}",
