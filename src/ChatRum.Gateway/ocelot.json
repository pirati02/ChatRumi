      "DownstreamHttpVersion": "1.1",
      "LoadBalancerOptions": {
        "Type": "LeastConnection"
      }
    }
  ],
  "GlobalConfiguration": {
    "UseServiceDiscovery": true,
    "BaseUrl": "http://localhost:7000",
    "ServiceDiscoveryProvider": {
      "Scheme": "http",
      "Host": "consul",
      "Port": 8500,
      "Type": "Consul",
      "PollingInterval": 10000
    },
    "LoadBalancerOptions": {
      "Type": "LeastConnection"
    }
  }
