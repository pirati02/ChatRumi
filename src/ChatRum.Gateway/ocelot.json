{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/account/{everything}",
      "DownstreamScheme": "http",
      "ServiceName": "accountservice",
      "UpstreamPathTemplate": "/account/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
      "LoadBalancerOptions": {
        "Type": "LeastConnection"
      }
    },
    {
      "DownstreamPathTemplate": "/api/chat/{everything}",
      "DownstreamScheme": "http",
      "ServiceName": "chatservice",
      "UpstreamPathTemplate": "/chat/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
      "LoadBalancerOptions": {
        "Type": "LeastConnection"
      }
    },
    {
      "DownstreamPathTemplate": "/api/friendship/{everything}",
      "DownstreamScheme": "http",
      "ServiceName": "friendshipservice",
      "UpstreamPathTemplate": "/friendship/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
      "LoadBalancerOptions": {
        "Type": "LeastConnection"
      }
    },
    {
      "DownstreamPathTemplate": "/hub/chat",
      "DownstreamScheme": "http",
      "ServiceName": "chatservice",
      "UpstreamPathTemplate": "/hub/chat",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "UseWebSockets": true,
      "DownstreamHttpVersion": "1.1",
      "LoadBalancerOptions": {
        "Type": "LeastConnection"
      }
    }
  ],
  "GlobalConfiguration": {
    "UseServiceDiscovery": true,
    "BaseUrl": "https://localhost:5136",
    "ServiceDiscoveryProvider": {
      "Host": "consul",
      "Port": 8500,
      "Type": "Consul",
      "PollingInterval": 10000
    }
  }
}
