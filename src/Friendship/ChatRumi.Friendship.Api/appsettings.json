{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "ChatRumi",
    "Audience": "ChatRumi",
    "SigningKey": "local_dev_jwt_signing_key_at_least_32_chars",
    "AccessTokenExpirationMinutes": 60
  },
  "Neo4jOptions": {
    "Neo4jConnection": "bolt://neo4j:7687",
    "Neo4jUser": "neo4j",
    "Neo4jPassword": "",
    "Neo4jDatabase": "neo4j"
  },
  "ConsulOptions": {
    "ServiceName": "friendshipservice",
    "ServiceAddress": "http://friendship-service:5031",
    "Host": "consul",
    "Scheme": "http",
    "Port": 8500,
    "Enabled": true
  },
  "OpenTelemetry": {
    "ServiceName": "friendship-service",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://jaeger:4317",
    "Enabled": true
  }
}
