{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ],
    "AllowCredentials": false
  },
  "Jwt": {
    "Issuer": "ChatRumi",
    "Audience": "ChatRumi",
    "SigningKey": "local_dev_jwt_signing_key_at_least_32_chars",
    "AccessTokenExpirationMinutes": 60
  },
  "ConnectionStrings": {
    "FeedContext": "http://elasticsearch:9200"
  },
  "Outbox": {
    "BatchSize": 50,
    "PollIntervalMs": 1000,
    "MaxAttempts": 10,
    "InitialRetryDelayMs": 500,
    "MaxRetryDelayMs": 30000
  },
  "ConsulOptions": {
    "ServiceName": "feedservice",
    "ServiceAddress": "http://feed-service:5211",
    "Host": "consul",
    "Scheme": "http",
    "Port": 8500,
    "Enabled": true
  },
  "OpenTelemetry": {
    "ServiceName": "feed-service",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://jaeger:4317",
    "Enabled": true
  }
}
